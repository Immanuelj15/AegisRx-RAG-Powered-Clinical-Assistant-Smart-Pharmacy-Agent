{
  "name": "aegisrx-root",
  "version": "1.0.0",
  "description": "AegisRx - RAG-Powered Clinical Assistant & Smart Pharmacy Agent - Root Project",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "npx prisma generate",
    "server": "nodemon server.js",
    "client": "npm run dev --prefix client",
    "rag": "python backend/services/rag_service.py",
    "dev": "concurrently \"npm run server\" \"npm run client\" \"npm run rag\"",
    "install:all": "npm install && npm install --prefix client && pip install flask flask-cors chromadb sentence-transformers pandas"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "google-auth-library": "^10.7.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.1",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.15.0",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.2",
    "prisma": "^7.8.0"
  },
  "author": "Senior Full Stack AI Engineer",
  "license": "MIT"
}
